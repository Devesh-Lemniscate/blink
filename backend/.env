# Blink URL Shortener - Backend Environment Variables

# MongoDB Connection URI
MONGO_URI=mongodb://127.0.0.1:27017/blink

# Application URL (used for generating short URLs)
APP_URL=http://localhost:3000/

# JWT Secret Key
JWT_SECRET=thisisasecretkey

# Node Environment
NODE_ENV=development

# Server Port
PORT=3000

# Redis Configuration (Optional - app works without it)
# For local Redis: redis://localhost:6379
# For Redis Cloud/Upstash: redis://username:password@host:port
# Leave empty or comment out to run without Redis
# REDIS_URL=redis://localhost:6379