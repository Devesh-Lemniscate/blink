# Blink URL Shortener - Backend Environment Variables

# MongoDB Connection URI
# Local: mongodb://localhost:27017/blink
# Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/blink
MONGO_URI=your_mongodb_connection_uri

# Application URL (used for generating short URLs)
APP_URL=your_app_base_url

# JWT Secret Key (use a strong, unique secret in production)
JWT_SECRET=your_jwt_secret_key

# Node Environment (development, production, test)
NODE_ENV=development

# Server Port
PORT=3000

# Redis Connection URL (OPTIONAL - app works without it)
# Leave empty or commented out to run without Redis caching
# The app will fall back to database-only mode with in-memory rate limiting
#
# Local Redis: redis://localhost:6379
# Upstash: redis://default:<password>@<region>.upstash.io:6379
# Redis Cloud: redis://default:<password>@<host>:<port>
#
# REDIS_URL=redis://localhost:6379
